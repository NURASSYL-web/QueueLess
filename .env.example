# QueueLess team setup template
# This file is a reference checklist for teammates and deployment setup.
# The current demo project already includes working Firebase values in code.
# QueueLess does not auto-load .env files at runtime yet.

APP_NAME=QueueLess
APP_ENV=demo

# Firebase project
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Firebase Web
FIREBASE_WEB_API_KEY=your-web-api-key
FIREBASE_WEB_APP_ID=your-web-app-id
FIREBASE_WEB_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_WEB_MEASUREMENT_ID=your-measurement-id

# Firebase Android
FIREBASE_ANDROID_API_KEY=your-android-api-key
FIREBASE_ANDROID_APP_ID=your-android-app-id
ANDROID_PACKAGE_NAME=com.queueless.app

# Firebase iOS
FIREBASE_IOS_API_KEY=your-ios-api-key
FIREBASE_IOS_APP_ID=your-ios-app-id
IOS_BUNDLE_ID=com.queueless.app

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional team notes
DEFAULT_CITY=Taraz
DEFAULT_COUNTRY=Kazakhstan

# Launch checklist
# 1. Update app_firebase_options.dart if moving to another Firebase project
# 2. Update AndroidManifest.xml Google Maps key
# 3. Update iOS Info.plist Google Maps key
# 4. Update web/index.html Google Maps key
# 5. Apply Firestore rules
# 6. Apply Storage rules
# 7. Seed Firestore with assets/seed/taraz_places.json
